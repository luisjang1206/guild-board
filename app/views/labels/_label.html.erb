<div id="label_<%= label.id %>" class="flex items-center gap-3 border-2 border-black bg-white p-3 shadow-[3px_3px_0px_var(--color-black)]">
  <span class="h-5 w-5 flex-shrink-0 border-2 border-black"
        style="background-color: <%= label.color %>;"
        aria-hidden="true"></span>
  <span class="flex-1 text-sm font-bold uppercase text-black"><%= label.name %></span>
  <span class="text-xs font-mono text-gray-500"><%= label.color %></span>
  <div class="flex items-center gap-2">
    <%= link_to edit_project_label_path(project, label),
        data: { turbo_frame: "modal" },
        class: "border-2 border-black bg-white px-2 py-1 text-xs font-bold uppercase shadow-[2px_2px_0px_var(--color-black)] transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[4px_4px_0px_var(--color-black)] active:translate-x-0.5 active:translate-y-0.5 active:shadow-[1px_1px_0px_var(--color-black)]" do %>
      <%= t("defaults.buttons.edit") %>
    <% end %>
    <%= button_to project_label_path(project, label),
        method: :delete,
        data: { turbo_confirm: t("labels.confirm_delete") },
        class: "border-2 border-black bg-red-100 px-2 py-1 text-xs font-bold uppercase shadow-[2px_2px_0px_var(--color-black)] transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[4px_4px_0px_var(--color-black)] active:translate-x-0.5 active:translate-y-0.5 active:shadow-[1px_1px_0px_var(--color-black)] cursor-pointer" do %>
      <%= t("defaults.buttons.delete") %>
    <% end %>
  </div>
</div>
