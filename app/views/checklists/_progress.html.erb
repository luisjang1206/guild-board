<%
  completed = task.checklists.count(&:completed)
  total = task.checklists.size
  pct = total > 0 ? (completed.to_f / total * 100).round : 0
%>
<div class="mb-2 flex items-center gap-2">
  <h3 class="text-xs font-bold uppercase text-gray-500"><%= t("checklists.progress.title") %></h3>
  <span class="border-2 border-black bg-yellow-300 px-1.5 py-0.5 text-xs font-bold shadow-[2px_2px_0px_#000000]">
    <%= completed %>/<%= total %>
  </span>
</div>
<div class="mb-3 h-2 w-full border-2 border-black bg-white shadow-[2px_2px_0px_#000000]">
  <div class="h-full bg-yellow-300 transition-all"
       style="width: <%= pct %>%;"
       role="progressbar"
       aria-valuenow="<%= completed %>"
       aria-valuemin="0"
       aria-valuemax="<%= total %>"></div>
</div>
