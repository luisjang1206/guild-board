<li id="checklist_<%= checklist.id %>" class="flex items-center gap-2">
  <%= button_to project_task_checklist_path(project, task, checklist),
      method: :patch,
      params: { checklist: { completed: !checklist.completed, content: checklist.content } },
      class: "flex-shrink-0 cursor-pointer",
      aria: { label: checklist.completed ? "Mark as incomplete" : "Mark as complete" } do %>
    <span class="flex h-5 w-5 items-center justify-center border-2 border-black bg-white shadow-[1px_1px_0px_#000000] transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[3px_3px_0px_#000000]">
      <% if checklist.completed %>
        <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
      <% end %>
    </span>
  <% end %>
  <span class="flex-1 text-sm <%= checklist.completed ? 'line-through text-gray-400' : 'text-black' %>">
    <%= checklist.content %>
  </span>
  <%= button_to project_task_checklist_path(project, task, checklist),
      method: :delete,
      data: { turbo_confirm: "Remove this item?" },
      class: "flex-shrink-0 cursor-pointer border-2 border-black bg-white px-1.5 py-0.5 text-xs font-bold uppercase shadow-[1px_1px_0px_#000000] transition-all hover:bg-red-100 hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[3px_3px_0px_#000000] active:translate-x-0.5 active:translate-y-0.5 active:shadow-none",
      aria: { label: "Delete checklist item" } do %>
    &times;
  <% end %>
</li>
