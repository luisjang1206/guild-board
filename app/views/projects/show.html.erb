<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
  <div class="mb-8">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-bold uppercase text-black"><%= @project.name %></h1>
      <div class="flex gap-2">
        <%= render ButtonComponent.new(tag: :a, href: edit_project_path(@project), variant: :secondary, style: :neo) do %>
          <%= t(".settings") %>
        <% end %>
      </div>
    </div>
    <% if @project.description.present? %>
      <p class="mt-2 text-black"><%= @project.description %></p>
    <% end %>
  </div>

  <%# Board columns overview %>
  <div class="mb-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-bold uppercase text-black"><%= t(".board") %></h2>
      <%= render ButtonComponent.new(tag: :a, href: project_board_path(@project), variant: :secondary, style: :neo) do %>
        <%= t(".open_board") %>
      <% end %>
    </div>
    <div class="flex gap-4 overflow-x-auto pb-4">
      <% @board_columns.each do |column| %>
        <% tasks = column.tasks.reject(&:soft_deleted?) %>
        <div class="w-72 flex-shrink-0 border-2 border-black bg-white shadow-[4px_4px_0px_#000000]">
          <div class="border-b-2 border-black px-4 py-3 bg-gray-50 flex items-center justify-between">
            <h3 class="text-sm font-bold uppercase text-black"><%= column.name %></h3>
            <span class="border-2 border-black bg-yellow-300 px-2 py-0.5 text-xs font-bold shadow-[2px_2px_0px_#000000]"><%= tasks.size %></span>
          </div>
          <div class="max-h-[400px] overflow-y-auto p-3 space-y-3">
            <% if tasks.empty? %>
              <p class="text-xs text-gray-400 text-center py-6"><%= t(".no_tasks_in_column") %></p>
            <% else %>
              <% tasks.each do |task| %>
                <%= render TaskCardComponent.new(task: task, link_target: nil) %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# API Keys section %>
  <div class="mb-8" id="project-keys">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-bold uppercase text-black"><%= t(".api_keys") %></h2>
    </div>

    <%# New key creation form %>
    <%= form_with url: project_project_keys_path(@project), method: :post, class: "mb-4 flex items-end gap-3" do |form| %>
      <div class="flex-1">
        <%= form.label :name, t("project_keys.component.key_name_label"), class: "block text-sm font-bold uppercase text-black mb-1" %>
        <%= form.text_field :name, class: "block w-full border-2 border-black py-1.5 text-black shadow-[3px_3px_0px_#000000] placeholder:text-gray-500 focus:-translate-x-px focus:-translate-y-px focus:shadow-[5px_5px_0px_#000000] focus:outline-none sm:text-sm", placeholder: "e.g., CI/CD Key", required: true %>
      </div>
      <%= render ButtonComponent.new(type: "submit", style: :neo) do %>
        <%= t("project_keys.component.create_key") %>
      <% end %>
    <% end %>

    <% if @project_keys.any? %>
      <div class="space-y-3">
        <% @project_keys.each do |key| %>
          <%= render ProjectKeyComponent.new(
            project_key: key,
            project: @project,
            raw_key: (flash[:project_key] if flash[:project_key_prefix].present? && key.key_prefix == flash[:project_key_prefix])
          ) %>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm font-bold text-black"><%= t(".no_keys") %></p>
    <% end %>
  </div>
</div>
