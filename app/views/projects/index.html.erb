<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-gray-900"><%= t(".title") %></h1>
    <%= render ButtonComponent.new(tag: :a, href: new_project_path) do %>
      <%= t(".new_project") %>
    <% end %>
  </div>

  <% if @projects.any? %>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <% @projects.each do |project| %>
        <%= render CardComponent.new do |card| %>
          <% card.with_title do %>
            <%= link_to project.name, project, class: "hover:text-indigo-600" %>
          <% end %>
          <% card.with_body do %>
            <p class="text-sm text-gray-500 line-clamp-2"><%= project.description %></p>
          <% end %>
          <% card.with_footer do %>
            <div class="flex items-center justify-between text-xs text-gray-400">
              <span><%= l(project.created_at, format: :short) %></span>
              <span><%= project.tasks.active.count %> tasks</span>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <%= render PaginationComponent.new(pagy: @pagy) %>
  <% else %>
    <%= render EmptyStateComponent.new(message: t(".empty")) do |empty| %>
      <% empty.with_icon do %>
        <svg class="mx-auto h-12 w-12" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z" />
        </svg>
      <% end %>
      <% empty.with_action do %>
        <%= render ButtonComponent.new(tag: :a, href: new_project_path) do %>
          <%= t(".new_project") %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
