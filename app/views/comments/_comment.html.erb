<li id="comment_<%= comment.id %>" class="border-2 border-black bg-gray-50 p-3 shadow-[3px_3px_0px_var(--color-black)]">
  <div class="mb-1 flex items-center gap-2">
    <% if comment.author_type == "agent" %>
      <svg class="h-4 w-4 flex-shrink-0 text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 1-6.23-.693L4.2 13.913m15.6 1.387-.166.467a2.25 2.25 0 0 1-2.12 1.483H6.486a2.25 2.25 0 0 1-2.12-1.483l-.165-.467M12 10.5a2.25 2.25 0 1 1 0-4.5 2.25 2.25 0 0 1 0 4.5Zm0 0v1.5" />
      </svg>
      <span class="text-xs font-bold uppercase text-gray-600"><%= t("comments.author.agent") %></span>
    <% else %>
      <svg class="h-4 w-4 flex-shrink-0 text-gray-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
      </svg>
      <span class="text-xs font-bold uppercase text-gray-600"><%= t("comments.author.user") %></span>
    <% end %>
    <time class="ml-auto text-xs text-gray-400" datetime="<%= comment.created_at.iso8601 %>">
      <%= comment.created_at.strftime("%b %d, %Y") %>
    </time>
  </div>
  <p class="whitespace-pre-wrap text-sm text-black"><%= comment.content %></p>
</li>
