<%= form_with url: project_task_comments_path(project, task),
    id: "comment-form",
    class: "space-y-3" do |form| %>
  <%= form.text_area :content,
      name: "comment[content]",
      rows: 3,
      placeholder: t("comments.form.placeholder"),
      required: true,
      class: "w-full resize-none border-2 border-black px-3 py-2 text-sm shadow-[3px_3px_0px_var(--color-black)] outline-none transition-all focus:-translate-x-px focus:-translate-y-px focus:shadow-[5px_5px_0px_var(--color-black)]" %>
  <div class="flex justify-end">
    <%= form.submit t("comments.form.submit"),
        class: "cursor-pointer border-2 border-black bg-yellow-300 px-4 py-2 text-sm font-bold uppercase shadow-[3px_3px_0px_var(--color-black)] transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[5px_5px_0px_var(--color-black)] active:translate-x-0.5 active:translate-y-0.5 active:shadow-[1px_1px_0px_var(--color-black)]" %>
  </div>
<% end %>
