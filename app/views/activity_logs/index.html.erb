<% content_for(:title) { t("activity_log.title") } %>

<div class="mb-6 flex items-center justify-between">
  <h1 class="text-2xl font-bold uppercase tracking-wide text-black"><%= t("activity_log.title") %></h1>
  <%= link_to t("defaults.buttons.back"), project_board_path(@project),
      class: "border-2 border-black bg-white px-4 py-2 text-sm font-bold uppercase shadow-[4px_4px_0px_#000000] transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-[6px_6px_0px_#000000]" %>
</div>

<div class="border-2 border-black bg-white p-4 shadow-[4px_4px_0px_#000000]">
  <% if @activity_logs.any? %>
    <% @activity_logs.each do |activity_log| %>
      <%= render(ActivityLogComponent.new(activity_log: activity_log, style: :neo)) %>
    <% end %>
  <% else %>
    <p class="py-8 text-center text-sm font-bold uppercase text-gray-400"><%= t("activity_log.empty") %></p>
  <% end %>
</div>

<%= render(PaginationComponent.new(pagy: @pagy)) %>
