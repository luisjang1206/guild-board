<% content_for(:title) { t("admin.project_keys.title") } %>

<h1 class="text-2xl font-bold text-gray-900 mb-8"><%= t("admin.project_keys.title") %></h1>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("admin.project_keys.name") %></th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("admin.project_keys.key_prefix") %></th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("admin.project_keys.project") %></th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("admin.project_keys.active") %></th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("admin.project_keys.last_used_at") %></th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t("admin.project_keys.created_at") %></th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @project_keys.each do |key| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= key.name %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-500"><%= key.key_prefix %>...</td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= link_to key.project.name, admin_project_path(key.project), class: "text-blue-600 hover:underline" %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <%= render(BadgeComponent.new(
              label: key.active? ? t("admin.project_keys.active_badge") : t("admin.project_keys.inactive_badge"),
              variant: key.active? ? :success : :error
            )) %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <% if key.respond_to?(:last_used_at) && key.last_used_at %>
              <%= l(key.last_used_at, format: :short) %>
            <% else %>
              <%= t("admin.project_keys.never_used") %>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= l(key.created_at, format: :short) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%= render(PaginationComponent.new(pagy: @pagy)) %>
