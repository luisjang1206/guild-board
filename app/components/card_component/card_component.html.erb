<div class="<%= css_classes %>">
  <% if title? %>
    <div class="<%= title_classes %>">
      <%= title %>
    </div>
  <% end %>

  <% if body? %>
    <div class="<%= body_classes %>">
      <%= body %>
    </div>
  <% end %>

  <% if footer? %>
    <div class="<%= footer_classes %>">
      <%= footer %>
    </div>
  <% end %>
</div>
