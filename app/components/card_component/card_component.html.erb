<div class="<%= css_classes %>">
  <% if title? %>
    <div class="mb-4 text-lg font-semibold text-gray-900">
      <%= title %>
    </div>
  <% end %>

  <% if body? %>
    <div class="text-gray-700">
      <%= body %>
    </div>
  <% end %>

  <% if footer? %>
    <div class="mt-4 border-t border-gray-100 pt-4">
      <%= footer %>
    </div>
  <% end %>
</div>
